# --- LLM: any OpenAI-compatible endpoint. Defaults target local Ollama. ---
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
# Better Arabic quality if your machine can run it:
# LLM_MODEL=qwen2.5:14b-instruct

# Example: use Groq instead of Ollama (fast cloud inference, free tier):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# --- Embeddings (multilingual; bge-m3 handles Arabic well) ---
# EMBED_BASE_URL defaults to LLM_BASE_URL
EMBED_MODEL=bge-m3

# --- Speech to text (faster-whisper) ---
WHISPER_MODEL=small
# WHISPER_MODEL=large-v3   # best Arabic accuracy, needs a GPU or patience
WHISPER_DEVICE=cpu

# --- Database backend ---
# Default: local SQLite (data/hospital.db), zero setup.
# To use Supabase/PostgreSQL + pgvector instead, paste your connection string
# (Supabase dashboard -> Connect -> Connection String -> Session pooler URI)
# and run `python scripts/seed_db.py` once.
# Prefer APP_DATABASE_URL: Chainlit intercepts a bare DATABASE_URL for its own
# data layer and can exhaust the Supabase session pooler.
# APP_DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# --- Misc ---
# DB_PATH=data/hospital.db
# LLM_TEMPERATURE=0.3
# LOG_LEVEL=INFO   # pipeline trace (router/slots/entity resolution); DEBUG for raw LLM output, WARNING to silence
